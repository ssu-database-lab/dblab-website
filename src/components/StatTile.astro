---
/**
 * Stat tile — mono tabular-nums value over a muted label.
 * Visual design ported from mockups/mockup_b.html (.stat).
 *
 * Props: { value: string; label: string }
 */
interface Props {
  value: string;
  label: string;
}

const { value, label } = Astro.props;
---

<div class="stat">
  <div class="stat-n">{value}</div>
  <div class="stat-l">{label}</div>
</div>

<style>
  .stat {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 14px 16px;
  }

  .stat-n {
    font-family: var(--mono);
    font-variant-numeric: tabular-nums;
    font-size: clamp(22px, 2.9vw, 30px);
    font-weight: 700;
    color: var(--accent-strong);
    letter-spacing: -0.02em;
  }

  .stat-l {
    font-size: var(--fs-caption);
    color: var(--muted);
    margin-top: 2px;
    line-height: 1.45;
  }
</style>
