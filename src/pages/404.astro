---
import Base from '../layouts/Base.astro';
---
<Base
  title="404 · Page not found — DB Lab · SSU"
  description="The requested page does not exist on the Database Lab website."
  lang="en"
  noindex
>
  {/* Base.astro already renders <main id="main"> around the slot — plain div here. */}
  <div class="nf">
    <div class="nf-in">
      <p class="nf-eyebrow" aria-hidden="true">query failed</p>

      {/* tabindex: the box scrolls horizontally on narrow screens (nowrap lines),
          so keyboard users need to be able to focus and scroll it. */}
      <div
        class="nf-term"
        role="img"
        tabindex="0"
        aria-label='Query failed. ERROR 404: relation "page" does not exist.'
      >
        <p class="nf-line">
          <span class="nf-prompt">dblab=#</span> SELECT * FROM page WHERE path = &#39;<span
            class="nf-path"
            id="nf-path">/this-page</span
          >&#39;;
        </p>
        <p class="nf-line nf-error">ERROR 404: relation &quot;page&quot; does not exist</p>
        <p class="nf-line nf-hint">
          HINT: the relation may have been dropped, renamed, or never migrated.
        </p>
        <p class="nf-line" aria-hidden="true">
          <span class="nf-prompt">dblab=#</span> <span class="nf-cursor"></span>
        </p>
      </div>

      {/* GitHub Pages serves ONE 404.html for every language's URLs,
          so this page is deliberately bilingual. */}
      <h1 class="nf-title">Page not found <span class="nf-title-ko" lang="ko">페이지를 찾을 수 없습니다</span></h1>
      <p class="nf-sub">
        The address may be mistyped, or the page may have moved. Try one of these instead.
      </p>
      <p class="nf-sub" lang="ko">
        주소가 잘못 입력되었거나 페이지가 이동되었을 수 있습니다. 아래 링크를 이용해 주세요.
      </p>

      <div class="nf-actions">
        <a class="nf-btn nf-btn-pri" href="/">Back to home · 홈으로</a>
        <a class="nf-btn nf-btn-gho" href="/publications">Publications · 논문</a>
      </div>
    </div>
  </div>
</Base>

<script>
  // Reflect the actual requested path into the fake query (textContent = safe).
  const el = document.getElementById('nf-path');
  if (el) {
    const p = window.location.pathname;
    el.textContent = p.length > 48 ? p.slice(0, 47) + '…' : p;
  }
</script>

<style>
  .nf {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: clamp(56px, 12vh, 130px) 20px clamp(72px, 14vh, 150px);
    display: flex;
    justify-content: center;
  }
  .nf-in {
    width: 100%;
    max-width: 640px;
  }
  .nf-eyebrow {
    font-family: var(--mono);
    font-size: var(--fs-eyebrow);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-strong);
    margin: 0 0 14px;
  }
  .nf-term {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-m);
    padding: 18px 20px;
    font-family: var(--mono);
    font-size: var(--fs-small);
    line-height: 1.75;
    overflow-x: auto;
  }
  .nf-line {
    margin: 0;
    white-space: nowrap;
  }
  .nf-prompt {
    color: var(--accent-strong);
    font-weight: 700;
  }
  .nf-path {
    color: var(--accent-strong);
  }
  .nf-error {
    font-weight: 700;
    color: var(--ink);
  }
  .nf-hint {
    color: var(--muted);
  }
  .nf-cursor {
    display: inline-block;
    width: 8px;
    height: 1em;
    vertical-align: text-bottom;
    background: var(--accent);
    animation: nf-blink 1.1s steps(1) infinite;
  }
  @keyframes nf-blink {
    50% {
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .nf-cursor {
      animation: none;
    }
  }
  .nf-title-ko {
    display: block;
    font-size: 0.62em;
    font-weight: 600;
    color: var(--muted);
    margin-top: 6px;
  }
  .nf-title {
    font-size: clamp(29px, 4.8vw, 40px);
    font-weight: 750;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 26px 0 0;
    color: var(--ink);
  }
  .nf-sub {
    color: var(--muted);
    margin: 10px 0 0;
    max-width: 52ch;
  }
  .nf-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 24px;
  }
  .nf-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 9px 18px;
    font-size: 15.5px;
    font-weight: 650;
    text-decoration: none;
    transition:
      box-shadow 0.15s ease,
      border-color 0.15s ease;
  }
  .nf-btn-pri {
    background: var(--accent);
    color: var(--accent-ink);
  }
  .nf-btn-pri:hover {
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 30%, transparent);
    text-decoration: none;
  }
  .nf-btn-gho {
    border-color: var(--line);
    background: var(--chip);
    color: var(--ink);
  }
  .nf-btn-gho:hover {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 30%, transparent);
    text-decoration: none;
  }
</style>
