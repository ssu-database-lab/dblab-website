---
/**
 * Alumni page — Database Lab, Soongsil University.
 * The 19-graduate ledger (adopted from mockups/mockup_a.html, restyled
 * in Proposal B's tokens): grouped Ph.D. → M.S., sorted NEWEST-FIRST
 * within each group, mono year column, KR thesis titles with EN when
 * available, "now →" destinations, hairline rules.
 *
 * Props: { lang: 'en' | 'ko' } — rendered by /alumni and /ko/alumni.
 */
import Base from '../layouts/Base.astro';
import alumni from '../data/alumni.json';
import { t, localizePath, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const ko = lang === 'ko';
const other: Lang = ko ? 'en' : 'ko';

/* Optional dept_kr/dept_en: rendered per row when a graduate's program
 * differs from the default (e.g. 어재현 — 정보과학대학원 소프트웨어공학과),
 * which is why the ledger header names only the Graduate School. */
type Alum = (typeof alumni)[number] & { dept_kr?: string; dept_en?: string };

/* Newest-first within each degree group. */
const byYearDesc = (a: { year: number }, b: { year: number }) => b.year - a.year;
const phd = (alumni as Alum[]).filter((a) => a.degree === 'PhD').sort(byYearDesc);
const ms = (alumni as Alum[]).filter((a) => a.degree === 'MS').sort(byYearDesc);
const total = alumni.length;

const alumniHeadline = ko
  ? `졸업생 ${total}명 — 박사 ${phd.length} · 석사 ${ms.length}`
  : `${total} alumni — ${phd.length} Ph.D. · ${ms.length} M.S.`;

const alumniDept = ko ? '숭실대학교 대학원' : 'Graduate School, Soongsil University';

const nowLabel = ko ? t(lang, 'people.now') : t(lang, 'people.now').toLowerCase();

const title = t(lang, 'section.alumni.title');
const description = ko
  ? `숭실대학교 데이터베이스연구실 졸업생 ${total}명 — 박사 ${phd.length}명, 석사 ${ms.length}명. 학위논문과 현재 소속(최신순).`
  : `The ${total} alumni of the Database Lab at Soongsil University — ${phd.length} Ph.D. and ${ms.length} M.S. graduates with theses and current positions, newest first.`;

const groups: { id: string; label: string; rows: Alum[] }[] = [
  { id: 'phd', label: t(lang, 'people.phd'), rows: phd },
  { id: 'ms', label: t(lang, 'people.ms'), rows: ms },
];
---

<Base title={title} description={description} lang={lang}>
  <section class="sec" id="alumni">
    <div class="wrap">
      <nav class="crumbs" aria-label={ko ? '탐색 경로' : 'Breadcrumb'}>
        <a href={localizePath(lang, '/people')}>← {t(lang, 'section.people.title')}</a>
      </nav>

      <div class="sec-head">
        <p class="eyebrow">
          {ko ? '졸업생' : 'Alumni'}<span class="eb-alt" lang={other}
            >{ko ? 'Alumni' : '졸업생'}</span
          >
        </p>
        <h1 class="page-t">
          {t(lang, 'section.alumni.title')}<span class="sec-ko" lang={other}
            >{t(other, 'section.alumni.title')}</span
          >
        </h1>
        <p class="page-s">{t(lang, 'section.alumni.sub')}</p>
      </div>

      <div class="al-head">
        <p class="al-n" aria-hidden="true">{total}</p>
        <div class="al-b">
          <p class="al-t">{alumniHeadline}</p>
          <p class="al-d">{alumniDept}</p>
        </div>
      </div>

      <div class="ledger">
        {
          groups.map((group) => (
            <section class="lgroup" aria-labelledby={`lg-${group.id}`}>
              <h2 class="lg-t" id={`lg-${group.id}`}>
                {group.label} <span class="lg-c">× {group.rows.length}</span>
              </h2>
              <ol class="lrows">
                {group.rows.map((a) => {
                  const alumMain = ko ? (a.name_kr ?? a.name_en) : a.name_en;
                  const alumAlt = ko ? a.name_en : a.name_kr;
                  return (
                    <li class="lrow">
                      <span class="ly">{a.year}</span>
                      <div class="lbody">
                        <p class="lname">
                          {alumMain}
                          {alumAlt && alumAlt !== alumMain && (
                            <span class="lname-alt" lang={other}>
                              {alumAlt}
                            </span>
                          )}
                          {a.unverified && (
                            <span class="lveri">
                              <span aria-hidden="true">⚠</span> {t(lang, 'common.unverified')}
                            </span>
                          )}
                        </p>
                        <p class="lthesis" lang="ko">
                          {a.thesis_kr}
                        </p>
                        {a.thesis_en && (
                          <p class="lthesis-en" lang="en">
                            {a.thesis_en}
                          </p>
                        )}
                        {(a.dept_kr || a.dept_en) && (
                          <p class="ldept" lang={ko || !a.dept_en ? 'ko' : 'en'}>
                            {ko ? (a.dept_kr ?? a.dept_en) : (a.dept_en ?? a.dept_kr)}
                          </p>
                        )}
                        {a.now && (
                          <p class="lnow" lang="en">
                            <span class="lnow-k" lang={lang}>
                              {nowLabel} →
                            </span>{' '}
                            {a.now}
                          </p>
                        )}
                      </div>
                    </li>
                  );
                })}
              </ol>
            </section>
          ))
        }
      </div>
    </div>
  </section>
</Base>

<style>
  .crumbs {
    margin-bottom: clamp(16px, 2.5vw, 24px);
  }

  .crumbs a {
    font-family: var(--mono);
    font-size: 14px;
    color: var(--muted);
  }

  .crumbs a:hover {
    color: var(--accent-strong);
  }

  .sec-head {
    margin-bottom: clamp(22px, 3.5vw, 34px);
  }

  .eb-alt {
    color: var(--muted);
    margin-left: 8px;
    letter-spacing: 0.04em;
  }

  .page-t {
    font-size: var(--fs-h1);
    font-weight: 800;
    letter-spacing: -0.025em;
    margin-top: 6px;
  }

  .page-s {
    color: var(--muted);
    margin-top: 8px;
    max-width: 64ch;
  }

  /* ---------- alumni summary ---------- */
  .al-head {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 20px 22px;
    display: flex;
    flex-wrap: wrap;
    gap: 6px 18px;
    align-items: center;
    margin-bottom: 14px;
  }

  .al-n {
    font-family: var(--mono);
    font-size: 38px;
    font-weight: 750;
    color: var(--accent-strong);
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
  }

  .al-b {
    flex: 1 1 300px;
    min-width: 0;
  }

  .al-t {
    font-weight: 700;
    font-size: 16.5px;
  }

  .al-d {
    font-size: 14.5px;
    color: var(--muted);
    margin-top: 2px;
  }

  /* ---------- alumni ledger (mockup A, restyled in B tokens) ---------- */
  .ledger {
    display: grid;
    gap: 14px;
  }

  .lgroup {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 6px 20px 10px;
  }

  .lg-t {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-family: var(--mono);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-strong);
    padding: 12px 0 10px;
    border-bottom: 1px solid var(--line-strong);
  }

  .lg-c {
    color: var(--muted);
    font-weight: 600;
    letter-spacing: 0;
    font-variant-numeric: tabular-nums;
  }

  .lrows {
    list-style: none;
  }

  .lrow {
    display: grid;
    grid-template-columns: 64px minmax(0, 1fr);
    gap: 2px 16px;
    padding: 13px 0;
  }

  .lrow + .lrow {
    border-top: 1px solid var(--line);
  }

  .ly {
    font-family: var(--mono);
    font-size: 14.5px;
    font-weight: 700;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
    padding-top: 2px;
  }

  .lname {
    font-size: 16px;
    font-weight: 650;
    letter-spacing: -0.005em;
    line-height: 1.4;
  }

  .lname-alt {
    font-weight: 500;
    color: var(--muted);
    font-size: 14px;
    margin-left: 7px;
  }

  .lveri {
    font-family: var(--mono);
    font-size: 11.5px;
    font-weight: 500;
    color: var(--muted);
    border: 1px dashed var(--line-strong);
    border-radius: var(--radius-s);
    padding: 1px 6px;
    margin-left: 8px;
    white-space: nowrap;
  }

  .lthesis {
    font-size: 14.5px;
    color: var(--muted);
    margin-top: 2px;
    line-height: 1.55;
  }

  .lthesis-en {
    font-size: 14px;
    color: var(--muted);
    font-style: italic;
    opacity: 0.85;
    margin-top: 1px;
    line-height: 1.5;
  }

  /* per-row degree program, shown when it differs from the ledger default */
  .ldept {
    font-family: var(--mono);
    font-size: var(--fs-micro);
    color: var(--muted);
    margin-top: 3px;
    line-height: 1.5;
  }

  .lnow {
    font-size: 14px;
    color: var(--accent-strong);
    margin-top: 4px;
    line-height: 1.5;
  }

  .lnow-k {
    font-family: var(--mono);
    font-size: var(--fs-micro);
    font-weight: 700;
  }

  /* single-column collapse for narrow phones (body never scrolls at 360px) */
  @media (max-width: 480px) {
    .lgroup {
      padding: 4px 14px 8px;
    }

    .lrow {
      grid-template-columns: 1fr;
      gap: 1px;
    }

    .ly {
      padding-top: 0;
    }
  }
</style>
