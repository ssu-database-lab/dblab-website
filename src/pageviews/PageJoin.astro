---
/**
 * Join page view — recruiting hero, audience blocks (Ph.D. · M.S. ·
 * undergraduate interns), "what you'll work on", what we offer,
 * how to apply (mailto CTA), the evergreen admissions-cycles
 * card, a 4-item FAQ, and a compact Teaching strip from courses.json.
 *
 * Visual design ported from mockups/mockup_b.html (#join: .join-card;
 * cards from .tcard/.rcard; chips from .chip/.vchip).
 * Rendered by the /join and /ko/join wrappers.
 */
import Base from '../layouts/Base.astro';
import Badge from '../components/Badge.astro';
import { t, localizePath, type Lang } from '../i18n/utils';
import courses from '../data/courses.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const ko = lang === 'ko';

/* Inline icon paths (ported from mockup_b.html's symbol sprite). */
const ICONS = {
  mail: {
    viewBox: '0 0 24 24',
    d: 'M4 5h16a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Zm1 3.2V17h14V8.2l-7 4.4-7-4.4ZM5.6 7l6.4 4 6.4-4H5.6Z',
  },
  link: {
    viewBox: '0 0 24 24',
    d: 'M14 4h6v6h-2V7.4l-7.3 7.3-1.4-1.4L16.6 6H14V4ZM5 6h6v2H7v9h9v-4h2v6H5V6Z',
  },
  arrow: {
    viewBox: '0 0 24 24',
    d: 'M13.2 5.2 20 12l-6.8 6.8-1.4-1.4 4.4-4.4H4v-2h12.2l-4.4-4.4 1.4-1.4Z',
  },
} as const;

const mailto = `mailto:djpark@ssu.ac.kr?subject=${encodeURIComponent(
  ko ? '[데이터베이스연구실] 대학원 진학 문의' : '[DB Lab] Graduate application inquiry',
)}`;

const copy = ko
  ? {
      metaTitle: '연구실 지원',
      metaDesc:
        '숭실대학교 데이터베이스연구실 대학원생(석사·박사)·학부연구생 모집 — 국가 R&D 과제, 국제 논문, 실전 시스템 연구.',
      eyebrow: '모집 · Join',
      chip: '대학원생 상시 문의 환영',

      positionsEyebrow: '모집 분야 · Open positions',
      positionsTitle: '모집 대상',
      positionsAside: 'Who we recruit',
      positionsSub: '연구실에 합류하는 세 가지 길 — 모두 이메일 한 통에서 시작합니다.',
      positions: [
        {
          k: 'Ph.D.',
          title: '박사과정',
          desc: '국가 R&D 과제 위에서 데이터셋 구축부터 모델, 배포 시스템까지 하나의 연구 주제를 끝까지 책임지고, 국제 학술지 실적을 쌓습니다. 외국인 지원자를 환영합니다.',
        },
        {
          k: 'M.S.',
          title: '석사과정',
          desc: '과제 팀에 합류해 진행 중인 연구 흐름 — 다중모달 보이스피싱 탐지, NER + LLM 메타데이터, 데이터 시스템 — 안에서 학위논문 주제를 구체화합니다. 밀착 지도와 실전형 연구 일정이 함께합니다.',
        },
        {
          k: 'Intern',
          title: '학부연구생',
          desc: '숭실대 학부생을 위한 실전 연구 경험 — 실제 데이터셋과 베이스라인, 주간 세미나. 석사과정으로 이어지는 자연스러운 진입로입니다.',
        },
      ],

      topicsEyebrow: '연구 주제 · Research topics',
      topicsTitle: '어떤 연구를 하게 되나요',
      topicsAside: "What you'll work on",
      topicsSub: '지금 진행 중이고, 과제가 뒷받침하며, 논문으로 이어지는 세 가지 연구 흐름.',
      topics: [
        {
          k: '보이스피싱 탐지',
          title: '다중모달 보이스피싱 탐지',
          desc: '오디오·텍스트 융합 한국어 보이스피싱 탐지, 실시간 탐지를 위한 경량 음향 모델, 그리고 KorCCVi 데이터셋 라인.',
          slug: 'vishing',
        },
        {
          k: 'NLP · 메타데이터',
          title: 'NER + LLM 권리 메타데이터 추출',
          desc: '한국어 공공저작물 권리문서를 위한 실제 배포 파이프라인 — 미세조정 한국어 NER와 스키마 기반 LLM 추출을 결합하고, 필드별 근거와 함께 하나의 스키마로 통합합니다.',
          slug: 'nlp-metadata',
        },
        {
          k: '스토리지 시스템',
          title: '스토리지 시스템의 전통',
          desc: '연구실의 시스템 DNA — 인용 700회를 넘긴 FAST FTL, 플래시 인지 인덱싱, 포렌식 데이터 복구 — 는 오늘의 강의와 시스템 지향 연구 문화로 이어집니다.',
          slug: 'flash-ftl',
        },
      ],
      linkArea: '연구 분야',

      offers: [
        {
          title: '국가 R&D 과제',
          desc: '문화체육관광부·KOCCA 공유저작물 메타데이터 R&D 컨소시엄(2025–2026)에 참여하는 등 국가 과제를 지속적으로 수행합니다.',
        },
        {
          title: '국제 논문 실적',
          desc: 'IEEE Access, MDPI Mathematics, ACM TECS 게재 실적과 KCC 2022 우수논문상(한국정보과학회)·ACK 2021 장려논문상(한국정보처리학회) 수상.',
        },
        {
          title: '실제 데이터셋과 시스템',
          desc: '국내 최초의 레이블링된 한국어 보이스피싱 통화 전사 데이터셋(KorCCVi), 공개 코드, 재현 가능한 벤치마크 — 실제로 배포되는 연구.',
        },
        {
          title: '지도와 세미나',
          desc: '주간 연구실 세미나와 밀착 지도, 연 100여 명 규모 강의의 조교(채점 자동화) 경험.',
        },
        {
          title: '국제적인 연구실 문화',
          desc: '가봉, 베트남, 중국 출신의 구성원과 졸업생 — 영어로도 편하게 협업하는 연구실입니다.',
        },
      ],

      steps: [
        {
          title: '박동주 교수님께 이메일',
          desc: 'CV와 성적증명서를 djpark@ssu.ac.kr로 보내면서, 하고 싶은 연구를 짧게 적어 주세요.',
        },
        {
          title: '연구실 면담',
          desc: '연구 주제와 적합성에 대한 짧은 대화 — 대면 또는 온라인으로 진행합니다.',
        },
        {
          title: '대학원 원서 접수',
          desc: '모집 기간에 숭실대학교 대학원에 원서를 접수합니다. (학부연구생은 이 단계가 없습니다.)',
        },
      ],

      admRows: [
        { k: '전기(봄) 입학', v: '원서접수 통상 10–11월' },
        { k: '후기(가을) 입학', v: '원서접수 통상 5–6월' },
      ],
      admNote:
        '정확한 모집 일정은 학기마다 숭실대학교 대학원 공고로 확정됩니다 — 지원 전에 grad.ssu.ac.kr에서 꼭 확인하세요.',

      faq: [
        {
          q: '대학원생 지원(인건비)이 제공되나요?',
          a: '대부분의 대학원생은 국가 R&D 과제에 참여하며, 연구 장학금과 인건비는 일반적으로 과제 참여를 통해 지원됩니다. 구체적인 조건은 입학 시점의 과제 상황에 따라 달라지므로, 면담 단계에서 교수님과 직접 상의하는 것이 가장 정확합니다.',
        },
        {
          q: '연구 주제는 어떻게 정하나요?',
          a: '학위논문 주제는 연구실이 실제로 수행 중인 흐름 — 다중모달 보이스피싱 탐지, NER + LLM 메타데이터 추출, 데이터 시스템 — 에서 출발합니다. 그 안에서 자신만의 문제를 정의할 여지가 충분하며, 보통 첫 학기를 지나며 주제가 또렷해집니다.',
        },
        {
          q: '외국인 학생도 지원할 수 있나요?',
          a: '물론입니다. 연구실은 국제적인 이력을 갖고 있습니다 — 베트남 출신 박사 졸업생 2명, 중국 출신 석사 졸업생, 그리고 현재 박사과정생은 가봉 출신입니다. 영어로 충분히 연구할 수 있으며, 한국어는 수업과 생활에 도움이 됩니다.',
        },
        {
          q: '학부생인데 연구에 참여할 수 있나요?',
          a: '네. 학부연구생은 연중 상시 모집합니다. 학년, 수강한 과목(데이터베이스·파일처리 수강 경험이 도움이 됩니다), 해보고 싶은 것을 적어 교수님께 메일을 보내 주세요 — 학부연구생 경험은 석사과정으로 자연스럽게 이어지는 경우가 많습니다.',
        },
      ],

      teachingEyebrow: '강의 · Teaching',
      teachingAside: 'Teaching',
      teachingSub: '연구실 주변에서 진행되는 강의 — 미래 구성원과 처음 만나는 접점입니다.',
      offerEyebrow: '혜택 · Offer',
      applyEyebrow: '지원 · Apply',
      faqEyebrow: '자주 묻는 질문 · FAQ',
      levelUndergrad: '학부',
      levelGrad: '대학원',
    }
  : {
      metaTitle: 'Join the Lab',
      metaDesc:
        'Recruiting M.S./Ph.D. students and undergraduate interns — funded national projects, international publications, systems that ship.',
      eyebrow: 'Join · 모집',
      chip: 'recruiting M.S. & Ph.D. — inquiries welcome',

      positionsEyebrow: 'Open positions',
      positionsTitle: 'Who We Recruit',
      positionsAside: '모집 대상',
      positionsSub: 'Three ways into the lab — all of them start with an email.',
      positions: [
        {
          k: 'Ph.D.',
          title: 'Ph.D. students',
          desc: 'Own a research line end-to-end on funded national projects — datasets, models, deployed systems — and build an international publication record. International applicants are welcome.',
        },
        {
          k: 'M.S.',
          title: 'M.S. students',
          desc: 'Join a funded project team and shape your thesis inside an active line — multimodal vishing detection, NER + LLM metadata, or data systems — with close advising and real research deadlines.',
        },
        {
          k: 'Intern',
          title: 'Undergraduate interns',
          desc: 'Hands-on research for Soongsil undergraduates — real datasets, real baselines, weekly seminars. A natural on-ramp to the M.S. program.',
        },
      ],

      topicsEyebrow: 'Research topics',
      topicsTitle: "What You'll Work On",
      topicsAside: '연구 주제',
      topicsSub: 'Current, funded, and publishable — three active lines you can join on day one.',
      topics: [
        {
          k: 'vishing',
          title: 'Multimodal vishing detection',
          desc: 'Audio–text fusion for Korean voice-phishing, lightweight acoustic models built for real-time detection, and the KorCCVi dataset line.',
          slug: 'vishing',
        },
        {
          k: 'nlp · metadata',
          title: 'NER + LLM rights-metadata extraction',
          desc: 'A deployed "division of labor" pipeline for Korean public-domain rights documents — fine-tuned Korean NER and schema-guided LLM extraction, consolidated with per-field provenance.',
          slug: 'nlp-metadata',
        },
        {
          k: 'storage systems',
          title: 'Storage systems heritage',
          desc: "The lab's systems DNA — the FAST flash translation layer (700+ citations), flash-aware indexing, and forensic data recovery — carried into today's coursework and systems-minded research culture.",
          slug: 'flash-ftl',
        },
      ],
      linkArea: 'Research area',

      offers: [
        {
          title: 'Funded national projects',
          desc: 'The lab co-runs the MCST/KOCCA copyright-metadata R&D consortium (2025–2026) and keeps an active national-project pipeline.',
        },
        {
          title: 'International publication record',
          desc: 'IEEE Access, MDPI Mathematics, ACM TECS — plus the KCC 2022 Outstanding Paper Award (KIISE) and ACK 2021 Encouragement Paper Award (KIPS).',
        },
        {
          title: 'Real datasets & systems',
          desc: 'The first labeled Korean voice-phishing transcript dataset (KorCCVi), open code, and reproducible benchmarks — research that ships.',
        },
        {
          title: 'Mentoring & seminars',
          desc: 'Weekly lab seminars, close advising, and TA experience (auto-grading infrastructure) on courses that run at ~100-student scale.',
        },
        {
          title: 'International lab culture',
          desc: 'Members and alumni from Gabon, Vietnam, and China — English-friendly collaboration in a Korean lab.',
        },
      ],

      steps: [
        {
          title: 'Email Prof. Park',
          desc: 'Send your CV and transcript to djpark@ssu.ac.kr, with a short note on what you want to work on.',
        },
        {
          title: 'Talk with the lab',
          desc: 'A short conversation about topics and fit — in person or online.',
        },
        {
          title: 'Apply to the Graduate School',
          desc: 'Submit your application to the Soongsil Graduate School during the admissions window. (Undergraduate interns skip this step.)',
        },
      ],

      admRows: [
        { k: 'Spring (전기) intake', v: 'applications usually Oct–Nov' },
        { k: 'Fall (후기) intake', v: 'applications usually May–Jun' },
      ],
      admNote:
        'Exact dates are announced each cycle by the Soongsil Graduate School — always check grad.ssu.ac.kr before applying.',

      faq: [
        {
          q: 'Are graduate positions funded?',
          a: 'Most graduate students work on funded national R&D projects, and research stipends are typically tied to project participation. Specifics depend on the project mix at the time you join — discuss the details with Prof. Park at the interview stage.',
        },
        {
          q: 'How are research topics chosen?',
          a: "Thesis topics grow out of the lab's active lines — multimodal vishing detection, NER + LLM metadata extraction, and data systems. Within those lines there is real room to define your own problem, and the topic usually sharpens over your first semester.",
        },
        {
          q: 'Do you accept international students?',
          a: 'Yes — the lab has a genuine international track record: two Ph.D. alumni from Vietnam, an M.S. graduate from China, and our current Ph.D. candidate is from Gabon. Research in English works fine; Korean helps with coursework and daily life.',
        },
        {
          q: "I'm an undergraduate — can I do research here?",
          a: 'Yes. We take Soongsil undergraduate interns year-round. Email Prof. Park with your year, the courses you have taken (Database and File Processing help), and what you would like to try — internships often lead into the M.S. program.',
        },
      ],

      teachingEyebrow: 'Teaching · 강의',
      teachingAside: '강의',
      offerEyebrow: 'Offer · 혜택',
      applyEyebrow: 'Apply · 지원',
      faqEyebrow: 'FAQ · 자주 묻는 질문',
      teachingSub: 'Courses taught around the lab — often the first contact point for future members.',
      levelUndergrad: 'Undergraduate',
      levelGrad: 'Graduate',
    };

/** A course is pending instructor/offering confirmation when its note says so. */
function isPending(course: (typeof courses)[number]): boolean {
  return /pending/i.test(course.note_en) || course.note_kr.includes('확인 중');
}
---

<Base title={copy.metaTitle} description={copy.metaDesc} lang={lang}>
  {/* ---------- recruiting hero ---------- */}
  <section class="sec" id="join">
    <div class="wrap">
      <div class="join-card">
        <div class="join-b">
          <p class="eyebrow">{copy.eyebrow}</p>
          <h1 class="join-t">{t(lang, 'join.title')}</h1>
          <p class="join-d">{t(lang, 'join.desc')}</p>
        </div>
        <div class="join-x">
          <span class="chip">
            <span class="dot" aria-hidden="true"></span>
            {copy.chip}
          </span>
          <a class="btn btn-pri" href={mailto}>
            <svg class="icon" viewBox={ICONS.mail.viewBox} aria-hidden="true">
              <path fill="currentColor" d={ICONS.mail.d}></path>
            </svg>
            {t(lang, 'join.cta')}
          </a>
          <a class="linkish" href="https://grad.ssu.ac.kr" target="_blank" rel="noopener">
            {t(lang, 'join.gradInfo')}
            <svg class="icon" viewBox={ICONS.link.viewBox} aria-hidden="true">
              <path fill="currentColor" d={ICONS.link.d}></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* ---------- audience blocks ---------- */}
  <section class="sec" id="positions">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow">{copy.positionsEyebrow}</p>
        <h2 class="sec-t">{copy.positionsTitle} <span class="sec-ko" lang={ko ? 'en' : 'ko'}>{copy.positionsAside}</span></h2>
        <p class="sec-s">{copy.positionsSub}</p>
      </div>
      <div class="grid3">
        {
          copy.positions.map((pos) => (
            <article class="card">
              <p class="card-k">{pos.k}</p>
              <h3 class="card-t">{pos.title}</h3>
              <p class="card-d">{pos.desc}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  {/* ---------- what you'll work on ---------- */}
  <section class="sec" id="topics">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow">{copy.topicsEyebrow}</p>
        <h2 class="sec-t">{copy.topicsTitle} <span class="sec-ko" lang={ko ? 'en' : 'ko'}>{copy.topicsAside}</span></h2>
        <p class="sec-s">{copy.topicsSub}</p>
      </div>
      <div class="grid3">
        {
          copy.topics.map((topic) => (
            <article class="card">
              <p class="card-k">{topic.k}</p>
              <h3 class="card-t">{topic.title}</h3>
              <p class="card-d">{topic.desc}</p>
              <div class="card-x">
                <a href={localizePath(lang, `/research#${topic.slug}`)}>
                  {copy.linkArea}
                  <svg class="icon" viewBox={ICONS.arrow.viewBox} aria-hidden="true">
                    <path fill="currentColor" d={ICONS.arrow.d} />
                  </svg>
                </a>
                <a href={localizePath(lang, `/publications?tag=${topic.slug}`)}>
                  {t(lang, 'research.relatedPapers')}
                  <svg class="icon" viewBox={ICONS.arrow.viewBox} aria-hidden="true">
                    <path fill="currentColor" d={ICONS.arrow.d} />
                  </svg>
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  {/* ---------- what we offer ---------- */}
  <section class="sec" id="offer">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow">{copy.offerEyebrow}</p>
        <h2 class="sec-t">{t(lang, 'join.offer')}</h2>
      </div>
      <ul class="offers" role="list">
        {
          copy.offers.map((offer) => (
            <li class="offer">
              <p class="offer-t">{offer.title}</p>
              <p class="offer-d">{offer.desc}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* ---------- how to apply + admissions dates ---------- */}
  <section class="sec" id="apply">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow">{copy.applyEyebrow}</p>
        <h2 class="sec-t">{t(lang, 'join.apply')}</h2>
        <p class="sec-s">{t(lang, 'join.applyDesc')}</p>
      </div>

      <div class="apply-grid">
        <div class="apply-steps">
          <ol class="steps" role="list">
            {
              copy.steps.map((step, i) => (
                <li class="step">
                  <span class="step-n" aria-hidden="true">
                    {String(i + 1).padStart(2, '0')}
                  </span>
                  <div class="step-b">
                    <p class="step-t">{step.title}</p>
                    <p class="step-d">{step.desc}</p>
                  </div>
                </li>
              ))
            }
          </ol>
          <p class="apply-cta">
            <a class="btn btn-pri" href={mailto}>
              <svg class="icon" viewBox={ICONS.mail.viewBox} aria-hidden="true">
                <path fill="currentColor" d={ICONS.mail.d}></path>
              </svg>
              {t(lang, 'join.cta')}
            </a>
          </p>
        </div>

        <aside class="adm-card" aria-labelledby="adm-title">
          <h3 class="adm-t" id="adm-title">{t(lang, 'join.admissions')}</h3>
          <dl class="adm-rows">
            {
              copy.admRows.map((row) => (
                <div class="adm-row">
                  <dt>{row.k}</dt>
                  <dd>{row.v}</dd>
                </div>
              ))
            }
          </dl>
          <p class="adm-note">{copy.admNote}</p>
          <a class="linkish" href="https://grad.ssu.ac.kr" target="_blank" rel="noopener">
            grad.ssu.ac.kr
            <svg class="icon" viewBox={ICONS.link.viewBox} aria-hidden="true">
              <path fill="currentColor" d={ICONS.link.d}></path>
            </svg>
          </a>
        </aside>
      </div>
    </div>
  </section>

  {/* ---------- FAQ ---------- */}
  <section class="sec" id="faq">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow">{copy.faqEyebrow}</p>
        <h2 class="sec-t">{t(lang, 'join.faq')}</h2>
      </div>
      <div class="faq-list">
        {
          copy.faq.map((item) => (
            <details class="faq">
              <summary class="faq-q">
                {item.q}
                <span class="faq-mark" aria-hidden="true">
                  +
                </span>
              </summary>
              <p class="faq-a">{item.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  {/* ---------- teaching strip ---------- */}
  <section class="sec" id="teaching">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow">{copy.teachingEyebrow}</p>
        <h2 class="sec-t">
          {t(lang, 'section.teaching.title')}
          <span class="sec-ko" lang={ko ? 'en' : 'ko'}>{copy.teachingAside}</span>
        </h2>
        <p class="sec-s">{copy.teachingSub}</p>
      </div>
      <div class="tgrid">
        {
          courses
            .filter((course) => course.featured)
            .map((course) => (
            <article class="tcard">
              <h3 class="tcard-t">
                {ko ? course.name_kr : course.name_en}
                <span class="sec-ko" lang={ko ? 'en' : 'ko'}>{ko ? course.name_en : course.name_kr}</span>
              </h3>
              <div class="tmeta">
                <span class="vchip">
                  {course.level === 'grad' ? copy.levelGrad : copy.levelUndergrad}
                </span>
                {isPending(course) && (
                  <Badge kind="unverified" label={t(lang, 'common.unverified')} />
                )}
              </div>
              <p class="tcard-d">{ko ? course.desc_kr : course.desc_en}</p>
              <p class="tcard-n">{ko ? course.note_kr : course.note_en}</p>
              {course.links.length > 0 && (
                <div class="tcard-x">
                  {course.links.map((link) => (
                    <a href={link.url} target="_blank" rel="noopener">
                      {link.label}
                      <svg class="icon" viewBox={ICONS.link.viewBox} aria-hidden="true">
                        <path fill="currentColor" d={ICONS.link.d} />
                      </svg>
                      <span class="sr-only">({t(lang, 'common.external')})</span>
                    </a>
                  ))}
                </div>
              )}
            </article>
          ))
        }
      </div>
    </div>
  </section>
</Base>

