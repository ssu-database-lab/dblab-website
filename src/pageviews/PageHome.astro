    font-weight: 750;
    letter-spacing: -0.02em;
    margin-top: 6px;
  }

  .join-d {
    color: var(--muted);
    margin-top: 10px;
    max-width: 58ch;
    font-size: var(--fs-body-s);
  }

  .join-x {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: flex-start;
