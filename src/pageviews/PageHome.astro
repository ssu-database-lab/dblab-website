</style>

<script>
  /* ---------- hero schema-graph canvas (ported from mockup B) ----------
   * Drifting nodes/edges suggesting a database schema diagram.
   *   - static single frame under prefers-reduced-motion
   *   - theme-aware colors, re-read on <html data-theme> mutation
   *     and on OS color-scheme change (covers the no-attribute case)
   *   - animation pauses while the tab is hidden
   */
  const canvas = document.getElementById('schema') as HTMLCanvasElement | null;
  const hero = canvas?.parentElement ?? null;
  const ctx = canvas?.getContext('2d') ?? null;

  if (canvas && hero && ctx) {
    const reducedMq = window.matchMedia('(prefers-reduced-motion: reduce)');
    const darkMq = window.matchMedia('(prefers-color-scheme: dark)');

    type SchemaNode = { x: number; y: number; vx: number; vy: number; r: number; tbl: boolean };
    let nodes: SchemaNode[] = [];
    let W = 0;
    let H = 0;
    let rafId = 0;
    let running = false;
    const colors = { accent: '#00707d', faint: '#52686e' };

    const readColors = (): void => {
      const cs = getComputedStyle(document.documentElement);
      colors.accent = cs.getPropertyValue('--accent').trim() || colors.accent;
      colors.faint = cs.getPropertyValue('--muted').trim() || colors.faint;
    };

    const makeNode = (): SchemaNode => ({
      x: Math.random() * W,
      y: Math.random() * H,
      vx: (Math.random() - 0.5) * 0.3,
      vy: (Math.random() - 0.5) * 0.3,
      r: 1.6 + Math.random() * 1.8,
      tbl: Math.random() < 0.28,
    });

    const targetCount = (): number => Math.max(14, Math.min(30, Math.round(W / 46)));

    const seed = (): void => {
      nodes = [];
      const n = targetCount();
      for (let i = 0; i < n; i++) nodes.push(makeNode());
    };

    const draw = (): void => {
      ctx.clearRect(0, 0, W, H);
      ctx.lineWidth = 1;
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const a = nodes[i];
          const b = nodes[j];
          const d = Math.hypot(a.x - b.x, a.y - b.y);
          if (d < 150) {
            ctx.globalAlpha = (1 - d / 150) * 0.16;
            ctx.strokeStyle = colors.faint;
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.stroke();
          }
        }
      }
      for (let i = 0; i < nodes.length; i++) {
        const a = nodes[i];
        if (a.tbl) {
          /* tiny table glyph */
          ctx.globalAlpha = 0.3;
          ctx.strokeStyle = colors.accent;
          ctx.strokeRect(a.x - 6, a.y - 4.5, 12, 9);
          ctx.beginPath();
          ctx.moveTo(a.x - 6, a.y - 1.5);
          ctx.lineTo(a.x + 6, a.y - 1.5);
          ctx.stroke();
        } else {
          ctx.globalAlpha = 0.38;
          ctx.fillStyle = colors.accent;
          ctx.beginPath();
          ctx.arc(a.x, a.y, a.r, 0, Math.PI * 2);
          ctx.fill();
        }
      }
      ctx.globalAlpha = 1;
    };

    let lastDpr = 0;

    const resize = (): void => {
      const rect = hero.getBoundingClientRect();
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      /* Mobile URL-bar collapse fires resize while scrolling — bail out
       * when nothing actually changed so the graph doesn't re-scatter. */
      if (rect.width === W && rect.height === H && dpr === lastDpr) return;
      const prevW = W;
      const prevH = H;
      W = rect.width;
      H = rect.height;
      lastDpr = dpr;
      canvas.width = Math.round(W * dpr);
      canvas.height = Math.round(H * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      if (nodes.length === 0 || prevW <= 0 || prevH <= 0) {
        seed();
      } else {
        /* keep the existing constellation: rescale positions into the new
         * box and only add/remove nodes to hit the density target */
        const sx = W / prevW;
        const sy = H / prevH;
        for (const n of nodes) {
          n.x *= sx;
          n.y *= sy;
        }
        const n = targetCount();
        while (nodes.length > n) nodes.pop();
        while (nodes.length < n) nodes.push(makeNode());
      }
      draw();
    };

    const tick = (): void => {
      for (let i = 0; i < nodes.length; i++) {
        const n = nodes[i];
        n.x += n.vx;
        n.y += n.vy;
        if (n.x < -10) n.x = W + 10;
        if (n.x > W + 10) n.x = -10;
        if (n.y < -10) n.y = H + 10;
        if (n.y > H + 10) n.y = -10;
      }
      draw();
      rafId = requestAnimationFrame(tick);
    };

    const start = (): void => {
      if (!running && !reducedMq.matches && !document.hidden) {
        running = true;
        rafId = requestAnimationFrame(tick);
      }
    };

    const stop = (): void => {
      if (running) {
        cancelAnimationFrame(rafId);
        running = false;
      }
    };

    readColors();
    resize();
    start();

    window.addEventListener('resize', resize);

    /* pause while the tab is hidden */
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        stop();
      } else {
        start();
      }
    });

    /* theme changes: explicit toggle writes data-theme on <html> … */
    const repaint = (): void => {
      readColors();
      if (W) draw();
    };
    new MutationObserver(repaint).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme'],
    });
    /* … and the OS can flip the theme when no data-theme is set */
    if (typeof darkMq.addEventListener === 'function') {
      darkMq.addEventListener('change', repaint);
    }

    /* honor live changes to the reduced-motion preference */
    if (typeof reducedMq.addEventListener === 'function') {
      reducedMq.addEventListener('change', () => {
        if (reducedMq.matches) {
          stop();
          draw(); /* leave a static frame */
        } else {
          start();
        }
      });
    }
  }
</script>
